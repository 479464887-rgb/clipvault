<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>ClipVault</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:-apple-system,BlinkMacSystemFont,sans-serif;font-size:13px;color:#c9d1d9;background:#0d1117;width:360px;max-height:560px;display:flex;flex-direction:column}
header{padding:12px 16px;border-bottom:1px solid #21262d;display:flex;align-items:center;gap:10px;flex-shrink:0}
header h1{font-size:16px;font-weight:600;color:#58a6ff;white-space:nowrap}
header .badge{font-size:9px;background:#daa520;color:#fff;padding:1px 6px;border-radius:8px;font-weight:600}
#search{flex:1;padding:6px 10px;font-size:13px;border:1px solid #30363d;border-radius:6px;background:#161b22;color:#c9d1d9;outline:none}
#search:focus{border-color:#58a6ff}
#search::placeholder{color:#484f58}
.actions{padding:8px 16px;display:flex;gap:6px;border-bottom:1px solid #21262d;flex-shrink:0}
.btn{flex:1;padding:6px 0;text-align:center;font-size:12px;font-weight:600;border:1px solid #30363d;border-radius:6px;cursor:pointer;background:#21262d;color:#c9d1d9;transition:background 0.15s}
.btn:hover{background:#30363d}
.btn-primary{background:#238636;border-color:#238636}
.btn-primary:hover{background:#2ea043}
.btn-danger{color:#f85149;border-color:#30363d}
.btn-danger:hover{background:#da3633;color:#fff}
#clip-list{flex:1;overflow-y:auto;padding:8px 12px}
.clip{padding:8px 10px;margin-bottom:4px;background:#161b22;border:1px solid #30363d;border-radius:6px;cursor:pointer;transition:all 0.1s;position:relative}
.clip:hover{border-color:#58a6ff}
.clip.pinned{border-color:#daa520}
.clip-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:4px}
.clip-meta{font-size:10px;color:#8b949e;display:flex;gap:8px}
.clip-pin{font-size:12px;opacity:0.4;cursor:pointer;transition:opacity 0.1s}
.clip:hover .clip-pin,.clip-pin.active{opacity:1}
.clip-text{font-size:12px;color:#c9d1d9;line-height:1.4;max-height:40px;overflow:hidden;word-break:break-all}
.clip .clip-text{white-space:pre-wrap}
.empty{padding:40px 0;text-align:center;color:#484f58}
.empty .emoji{font-size:40px;margin-bottom:12px}
.empty p{font-size:13px}
footer{padding:8px 16px;border-top:1px solid #21262d;display:flex;justify-content:space-between;align-items:center;font-size:11px;color:#8b949e;flex-shrink:0}
footer a{color:#58a6ff;text-decoration:none}
.tooltip{position:absolute;top:-28px;right:0;background:#30363d;color:#c9d1d9;padding:2px 8px;border-radius:4px;font-size:11px;pointer-events:none;animation:fadeOut 1.5s ease forwards}
@keyframes fadeOut{0%{opacity:1}70%{opacity:1}100%{opacity:0}}
</style>
</head>
<body>
<header>
  <h1>📋 ClipVault</h1>
  <span class="badge">BETA</span>
  <input type="text" id="search" placeholder="搜索剪贴记录...">
</header>

<div class="actions">
  <button class="btn btn-primary" id="btn-paste">📥 粘贴保存</button>
  <button class="btn" id="btn-add">➕ 手动添加</button>
</div>

<div id="clip-list"></div>

<footer>
  <span id="stats"></span>
  <a href="#" id="btn-clear">清空全部</a>
  <a href="#" id="btn-settings">⚙️</a>
</footer>

<script src="popup.js"></script>
</body>
</html>
