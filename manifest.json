{
  "manifest_version": 3,
  "minimum_chrome_version": "88",
  "name": "ClipVault",
  "version": "1.0.0",
  "description": "智能剪贴板管理器 — 记录/搜索/收藏剪贴历史，效率翻倍",
  "homepage_url": "https://479464887-rgb.github.io/clipvault/",
  "author": {
    "email": "tulv202900@163.com"
  },
  "permissions": [
    "storage",
    "contextMenus",
    "clipboardWrite",
    "clipboardRead",
    "commands"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "ClipVault"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+V",
        "mac": "Command+Shift+V"
      },
      "description": "打开 ClipVault"
    }
  }
}